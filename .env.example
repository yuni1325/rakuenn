# ローカル開発
DATABASE_URL="file:./dev.db"
PLAYWRIGHT_HEADLESS=false

# 本番（Railway 等）
# DATABASE_URL="file:/data/dev.db"
# PLAYWRIGHT_HEADLESS=true
# NODE_ENV=production
# ACCESS_PASSWORD="your-secret-password"

# Bot検知回避（みんレポ向け。アナスロはステルス未使用）
# PLAYWRIGHT_STEALTH=true
# PLAYWRIGHT_LOCALE=ja-JP
# PLAYWRIGHT_TIMEZONE_ID=Asia/Tokyo
# PLAYWRIGHT_CHANNEL=chrome
# PLAYWRIGHT_ROTATE_UA="false"
# PLAYWRIGHT_ROTATE_VIEWPORT="false"

# スクレイピング設定（任意）
# SCRAPE_DELAY_MS=5000
# SCRAPE_MAX_DAYS=31
# SCRAPE_MAX_CONSECUTIVE_FAILURES=3
# SCRAPE_SESSION_REFRESH_EVERY=15
# SCRAPE_COOLDOWN_MS=30000
