  "scripts": {
    "dev": "next dev -p 3000",
    "dev:stop": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/stop-dev-server.ps1",
    "dev:restart": "npm run dev:stop && npm run dev",
